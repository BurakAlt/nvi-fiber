# Altıparmak ISP CRM — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyala ve doldur
# cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_PASSWORD=guclu_sifre_buraya

# ── Claude API ───────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-api03-...

# ── MikroTik ─────────────────────────────────────────────
# Ana router IP (birden fazla router varsa kod içinde her aboneye ayrı atanır)
MIKROTIK_HOST=192.168.1.1
MIKROTIK_USER=api_user
MIKROTIK_PASS=router_sifre

# ── WAHA (WhatsApp) ───────────────────────────────────────
WAHA_SESSION=altiparmak

# ── Güvenlik ─────────────────────────────────────────────
SECRET_KEY=cok_uzun_rastgele_string_buraya_en_az_32_karakter
